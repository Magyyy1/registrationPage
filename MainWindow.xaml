<Window x:Class="RegistrationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="500"
        Width="500"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="3"
                   Text="Регистрация"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="10"/>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="Логин:"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="10"/>

        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Width="180"
                 Height="30"
                 Padding="5"
                 Margin="10"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Пароль:"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="10"/>

        <PasswordBox Grid.Row="2"
                     Grid.Column="1"
                     Width="180"
                     Height="30"
                     Padding="5"
                     Margin="10"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>

        <Button Grid.Row="3"
                Grid.ColumnSpan="3"
                Content="Зарегистрироваться"
                Width="180"
                Height="40"
                FontSize="14"
                FontWeight="Bold"
                Background="#3498DB"
                Foreground="White"
                BorderThickness="0"
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
    </Grid>
</Window>